generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  lastname      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  favorites     UserFavorite[]
  chapterReads  UserChapterRead[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  isRevoked  Boolean  @default(false)
  replacedBy String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Series {
  id           Int     @id @default(autoincrement())
  name         String
  slug         String  @unique
  status       String?
  cover        String?
  chapterCount Int
  summary   String?

  lastChapterPublishedAt DateTime?
  metadataFetchedAt DateTime?

  chapters       Chapter[]
  providerSeries ProviderSeries[]
  genres         SeriesGenre[]
  favorites     UserFavorite[]

  lastChaptersCheck DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([slug])
  @@index([name])
  @@index([lastChapterPublishedAt])
}

model Chapter {
  id          Int      @id
  name        String
  publishedAt DateTime

  seriesId Int
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  pages            Page[]
  providerChapters ProviderChapter[]
  reads         UserChapterRead[]

  pagesScraped Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([seriesId])
  @@index([publishedAt])
}

model Page {
  id        Int     @id @default(autoincrement())
  url       String
  chapterId Int
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([url, chapterId])
  @@index([chapterId])
}

model Provider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  series   ProviderSeries[]
  chapters ProviderChapter[]
}

model ProviderSeries {
  id          Int    @id @default(autoincrement())
  providerId  Int
  seriesId    Int

  externalId  String
  slug        String
  url         String?

  summary     String?
  status      String?
  cover       String?

  provider    Provider @relation(fields: [providerId], references: [id])
  series      Series   @relation(fields: [seriesId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt

  @@unique([providerId, externalId])
  @@unique([providerId, seriesId])
}

model ProviderChapter {
  id Int @id @default(autoincrement())

  providerId Int
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  externalId Int

  chapterId Int
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId])
  @@index([chapterId])
}

model Genre {
  id    Int     @id @default(autoincrement())
  name  String  @unique

  series SeriesGenre[]
}

model SeriesGenre {
  seriesId Int
  genreId  Int

  series Series @relation(fields: [seriesId], references: [id])
  genre  Genre  @relation(fields: [genreId], references: [id])

  @@id([seriesId, genreId])
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    String
  seriesId  Int
  status    String   @default("Siguiendo") // "Siguiendo" | "Terminado"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([userId])
  @@map("user_favorites")
}

model UserChapterRead {
  id        Int      @id @default(autoincrement())
  userId    String
  chapterId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@map("user_chapter_reads")
}